# Publishable application key from TONE3000 Settings → API Keys.
TONE3000_CLIENT_ID=t3k_pub_your_key_here

# Both the site root and the versioned API URL are accepted.
TONE3000_BASE_URL=https://www.tone3000.com/api/v1

# Register this exact callback URI on the TONE3000 API key:
# http://localhost:43821/tone3000/callback
